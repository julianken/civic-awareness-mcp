{
  "name": "civic-awareness-mcp",
  "version": "0.0.6",
  "description": "MCP server for US federal and state legislative civic data",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "llm-tools",
    "openstates",
    "congress-gov",
    "openfec",
    "civic-tech",
    "legislative-data"
  ],
  "homepage": "https://github.com/julianken/civic-awareness-mcp#readme",
  "bugs": "https://github.com/julianken/civic-awareness-mcp/issues",
  "license": "MIT",
  "author": "Julian (https://github.com/julianken)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/julianken/civic-awareness-mcp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "civic-awareness-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -rf dist/core/migrations && cp -R src/core/migrations dist/core/migrations",
    "test": "vitest run --exclude tests/drift/**",
    "test:watch": "vitest",
    "test:drift": "vitest run tests/drift/",
    "bootstrap": "tsx src/cli/bootstrap.ts",
    "refresh": "tsx src/cli/refresh.ts",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
